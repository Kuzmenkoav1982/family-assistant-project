{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Valid event accepted",
      "method": "POST",
      "path": "/",
      "body": {
        "event_name": "portfolio_widget_open",
        "page": "/",
        "session_id": "test-session-1",
        "props": { "source": "dashboard" }
      },
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "New trust event accepted (portfolio_about_open)",
      "method": "POST",
      "path": "/",
      "body": {
        "event_name": "portfolio_about_open",
        "page": "/portfolio/about",
        "session_id": "test-session-trust",
        "props": { "source": "trust_block" }
      },
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Improve CTA event accepted with new props",
      "method": "POST",
      "path": "/",
      "body": {
        "event_name": "portfolio_improve_cta_click",
        "page": "/portfolio/abc",
        "session_id": "test-session-improve",
        "props": {
          "sphere": "emotions",
          "source_type": "children_mood_entries",
          "route": "/health",
          "level": "low"
        }
      },
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown event rejected",
      "method": "POST",
      "path": "/",
      "body": {
        "event_name": "totally_unknown_event"
      },
      "expectedStatus": 400,
      "expectedBody": { "code": "invalid_event" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Empty event_name rejected",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "Method not allowed",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405
    }
  ]
}