{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without admin token → 401",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401
    },
    {
      "name": "GET list with admin token returns 200",
      "method": "GET",
      "path": "/",
      "headers": { "X-Admin-Token": "admin_authenticated" },
      "expectedStatus": 200
    },
    {
      "name": "POST create without admin → 401",
      "method": "POST",
      "path": "/",
      "body": { "type": "info", "title": "x", "message": "y" },
      "expectedStatus": 401
    },
    {
      "name": "POST create with invalid type → 400",
      "method": "POST",
      "path": "/",
      "headers": { "X-Admin-Token": "admin_authenticated" },
      "body": { "type": "bogus", "title": "x", "message": "y" },
      "expectedStatus": 400
    },
    {
      "name": "POST create with empty title → 400",
      "method": "POST",
      "path": "/",
      "headers": { "X-Admin-Token": "admin_authenticated" },
      "body": { "type": "info", "title": "", "message": "y" },
      "expectedStatus": 400
    },
    {
      "name": "POST create with broken cta pair → 400",
      "method": "POST",
      "path": "/",
      "headers": { "X-Admin-Token": "admin_authenticated" },
      "body": { "type": "info", "title": "t", "message": "m", "ctaLabel": "click", "ctaHref": "" },
      "expectedStatus": 400
    },
    {
      "name": "POST create with ends before starts → 400",
      "method": "POST",
      "path": "/",
      "headers": { "X-Admin-Token": "admin_authenticated" },
      "body": { "type": "info", "title": "t", "message": "m", "startsAt": "2026-06-01T00:00:00Z", "endsAt": "2026-05-01T00:00:00Z" },
      "expectedStatus": 400
    }
  ]
}