{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },

    {
      "name": "CRUD: GET без токена → 401",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401
    },
    {
      "name": "CRUD: GET с фейковым токеном → 401",
      "method": "GET",
      "path": "/",
      "headers": { "X-Admin-Session-Token": "fake_token_not_in_db" },
      "expectedStatus": 401
    },
    {
      "name": "CRUD: POST create без токена → 401",
      "method": "POST",
      "path": "/",
      "body": { "type": "info", "title": "x", "message": "y" },
      "expectedStatus": 401
    },
    {
      "name": "CRUD: PUT update без токена → 401",
      "method": "PUT",
      "path": "/?id=00000000-0000-0000-0000-000000000000",
      "body": { "type": "info", "title": "x", "message": "y" },
      "expectedStatus": 401
    },
    {
      "name": "CRUD: DELETE без токена → 401",
      "method": "DELETE",
      "path": "/?id=00000000-0000-0000-0000-000000000000",
      "expectedStatus": 401
    },

    {
      "name": "SPOOFING: legacy X-Admin-Token: admin_authenticated → 401",
      "method": "GET",
      "path": "/",
      "headers": { "X-Admin-Token": "admin_authenticated" },
      "expectedStatus": 401
    },
    {
      "name": "SPOOFING: X-Admin-Actor подделка без токена → 401",
      "method": "POST",
      "path": "/",
      "headers": { "X-Admin-Actor": "hacker@evil.com" },
      "body": { "type": "info", "title": "x", "message": "y" },
      "expectedStatus": 401
    },

    {
      "name": "VALIDATION: invalid audience → 401 (нет auth, не 400)",
      "method": "POST",
      "path": "/",
      "body": { "type": "info", "title": "x", "message": "y", "audience": "all" },
      "expectedStatus": 401
    },
    {
      "name": "VALIDATION: audience=admins (old value) → 401 (нет auth, не 400)",
      "method": "POST",
      "path": "/",
      "body": { "type": "info", "title": "x", "message": "y", "audience": "admins" },
      "expectedStatus": 401
    },
    {
      "name": "SEG-1.6: invalid segment → 401 (нет auth, не 400)",
      "method": "POST",
      "path": "/",
      "body": { "type": "info", "title": "x", "message": "y", "segment": "unknown_segment" },
      "expectedStatus": 401
    },
    {
      "name": "VALIDATION: POST create с неверным type → 401 (нет auth, не 400)",
      "method": "POST",
      "path": "/",
      "body": { "type": "bogus", "title": "x", "message": "y" },
      "expectedStatus": 401
    },
    {
      "name": "VALIDATION: POST create с пустым title → 401 (нет auth, не 400)",
      "method": "POST",
      "path": "/",
      "body": { "type": "info", "title": "", "message": "y" },
      "expectedStatus": 401
    }
  ]
}