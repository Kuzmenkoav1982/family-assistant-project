{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Get reviews (public)",
      "method": "GET",
      "path": "/?type=review",
      "expectedStatus": 200,
      "expectedBody": {},
      "bodyMatcher": "partial"
    },
    {
      "name": "Ideas categories (public)",
      "method": "GET",
      "path": "/?resource=ideas&action=categories",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {}
    },
    {
      "name": "Ideas statuses (public)",
      "method": "GET",
      "path": "/?resource=ideas&action=statuses",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {}
    },
    {
      "name": "Ideas list (public)",
      "method": "GET",
      "path": "/?resource=ideas&sort_by=votes",
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {}
    },
    {
      "name": "X-Admin-Token legacy header on PUT → 403",
      "method": "PUT",
      "path": "/",
      "headers": {"X-Admin-Token": "admin_authenticated"},
      "body": {"id": "1", "status": "resolved"},
      "expectedStatus": 403
    },
    {
      "name": "X-Admin-Token legacy header on DELETE → 403",
      "method": "DELETE",
      "path": "/?id=1",
      "headers": {"X-Admin-Token": "admin_authenticated"},
      "expectedStatus": 403
    },
    {
      "name": "No token on PUT → 403",
      "method": "PUT",
      "path": "/",
      "body": {"id": "1", "status": "resolved"},
      "expectedStatus": 403
    }
  ]
}