{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "No token → 401",
      "method": "GET",
      "path": "/?action=dashboard",
      "expectedStatus": 401
    },
    {
      "name": "X-Admin-Token legacy header → 401",
      "method": "GET",
      "path": "/?action=dashboard",
      "headers": {"X-Admin-Token": "admin_authenticated"},
      "expectedStatus": 401
    }
  ]
}
