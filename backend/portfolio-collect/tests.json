{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing params returns 400",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Collect by member_id returns 200",
      "method": "GET",
      "path": "/?member_id=000000d1-0000-0000-0000-000000000001",
      "expectedStatus": 200,
      "expectedBody": {"collected": 0, "by_source": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Parity: all 13 source keys present in by_source",
      "method": "GET",
      "path": "/?member_id=000000d1-0000-0000-0000-000000000001",
      "expectedStatus": 200,
      "expectedBody": {
        "by_source": {
          "vital_records": 0,
          "children_vaccinations": 0,
          "children_doctor_visits": 0,
          "children_mood_entries": 0,
          "child_skills": 0,
          "children_activities": 0,
          "tasks_v2": 0,
          "children_piggybank": 0,
          "calendar_events": 0,
          "traditions": 0,
          "children_grades": 0,
          "children_dreams": 0,
          "children_medications": 0
        }
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Collect by family_id returns 200",
      "method": "GET",
      "path": "/?family_id=00000000-0000-0000-0000-000000000001",
      "expectedStatus": 200,
      "expectedBody": {"collected": 0},
      "bodyMatcher": "partial"
    }
  ]
}