    {"name": "X-Authorization wrong = 403", "method": "GET", "path": "/?action=health", "headers": {"X-Authorization": "Bearer wrong-xyz"}, "expectedStatus": 403},
    {"name": "Unknown action no auth = 403", "method": "GET", "path": "/?action=unknown", "expectedStatus": 403}
