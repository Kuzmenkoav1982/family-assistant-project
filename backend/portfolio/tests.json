      "expectedBody": {
        "debug": {
          "age_group": "7-10",
          "sphere_details": {
            "intellect": {"score": 4.0, "coverage": {"matched_groups": 1}},
            "values": {"score": 1.4, "coverage": {"matched_groups": 2}},
            "body": {"score": 3.0, "coverage": {"matched_groups": 1}}
          }
        }
      },
      "bodyMatcher": "partial"
    },
