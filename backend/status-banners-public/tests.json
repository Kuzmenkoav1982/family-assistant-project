{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "POST is rejected → 405",
      "method": "POST",
      "path": "/",
      "expectedStatus": 405
    },

    {
      "name": "TRUTH TABLE: anonymous → viewer=public, policy=server_resolved_v2",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": { "viewer": "public", "audience_policy": "server_resolved_v2" },
      "bodyMatcher": "partial"
    },
    {
      "name": "TRUTH TABLE: invalid X-Auth-Token → viewer=public (no privilege bump)",
      "method": "GET",
      "path": "/",
      "headers": { "X-Auth-Token": "invalid_token_not_in_db" },
      "expectedStatus": 200,
      "expectedBody": { "viewer": "public" },
      "bodyMatcher": "partial"
    },
    {
      "name": "TRUTH TABLE: invalid X-Admin-Session-Token → viewer=public (no privilege bump)",
      "method": "GET",
      "path": "/",
      "headers": { "X-Admin-Session-Token": "invalid_admin_token_not_in_db" },
      "expectedStatus": 200,
      "expectedBody": { "viewer": "public" },
      "bodyMatcher": "partial"
    },

    {
      "name": "SPOOFING: ?viewer=admin → viewer=public (ignored)",
      "method": "GET",
      "path": "/?viewer=admin",
      "expectedStatus": 200,
      "expectedBody": { "viewer": "public" },
      "bodyMatcher": "partial"
    },
    {
      "name": "SPOOFING: ?actor=admin → viewer=public (ignored)",
      "method": "GET",
      "path": "/?actor=admin",
      "expectedStatus": 200,
      "expectedBody": { "viewer": "public" },
      "bodyMatcher": "partial"
    },
    {
      "name": "SPOOFING: X-Admin-Token: admin_authenticated → viewer=public (legacy header ignored)",
      "method": "GET",
      "path": "/",
      "headers": { "X-Admin-Token": "admin_authenticated" },
      "expectedStatus": 200,
      "expectedBody": { "viewer": "public" },
      "bodyMatcher": "partial"
    },
    {
      "name": "SPOOFING: both ?viewer=admin + X-Admin-Token → viewer=public",
      "method": "GET",
      "path": "/?viewer=admin&actor=admin",
      "headers": { "X-Admin-Token": "admin_authenticated" },
      "expectedStatus": 200,
      "expectedBody": { "viewer": "public" },
      "bodyMatcher": "partial"
    },

    {
      "name": "CACHE: anonymous → Cache-Control: public",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedHeaders": { "Cache-Control": "public, max-age=30, must-revalidate" }
    }
  ]
}
