{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET anon returns 200",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET with X-Auth-Token returns 200",
      "method": "GET",
      "path": "/",
      "headers": { "X-Auth-Token": "fake-but-present" },
      "expectedStatus": 200
    },
    {
      "name": "GET with X-Admin-Token returns 200",
      "method": "GET",
      "path": "/",
      "headers": { "X-Admin-Token": "admin_authenticated" },
      "expectedStatus": 200
    },
    {
      "name": "POST is rejected",
      "method": "POST",
      "path": "/",
      "expectedStatus": 405
    }
  ]
}