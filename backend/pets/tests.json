{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Без токена — 401",
      "method": "GET",
      "path": "/?action=list_pets",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Неверный токен — 401",
      "method": "GET",
      "path": "/?action=list_pets",
      "headers": {"X-Auth-Token": "invalid-token-xxx"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
