{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing action",
      "method": "GET",
      "path": "/",
      "expectedStatus": 400,
      "expectedBody": {"error": "action_required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Index status returns shape",
      "method": "GET",
      "path": "/?action=index.status",
      "expectedStatus": 200
    },
    {
      "name": "Legacy seed.status alias",
      "method": "GET",
      "path": "/?action=seed.status",
      "expectedStatus": 200
    },
    {
      "name": "from_github requires owner/repo",
      "method": "POST",
      "path": "/",
      "body": {"action": "index.from_github"},
      "expectedStatus": 400,
      "expectedBody": {"error": "owner_repo_required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "from_local_paths requires repo",
      "method": "POST",
      "path": "/",
      "body": {"action": "index.from_local_paths"},
      "expectedStatus": 400,
      "expectedBody": {"error": "repo_required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "from_local_paths requires commit_sha",
      "method": "POST",
      "path": "/",
      "body": {"action": "index.from_local_paths", "repo": "owner/repo"},
      "expectedStatus": 400,
      "expectedBody": {"error": "commit_sha_required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "from_local_paths requires target_paths",
      "method": "POST",
      "path": "/",
      "body": {"action": "index.from_local_paths", "repo": "owner/repo", "commit_sha": "abc123"},
      "expectedStatus": 400,
      "expectedBody": {"error": "target_paths_required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "from_local_paths rejects bad repo format",
      "method": "POST",
      "path": "/",
      "body": {"action": "index.from_local_paths", "repo": "no-slash", "commit_sha": "abc", "target_paths": ["src/x.tsx"]},
      "expectedStatus": 400,
      "expectedBody": {"error": "repo_required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "from_snapshot requires files",
      "method": "POST",
      "path": "/",
      "body": {"action": "index.from_snapshot"},
      "expectedStatus": 400,
      "expectedBody": {"error": "files_required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "from_snapshot ingest one file",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "index.from_snapshot",
        "env": "stage",
        "commit_sha": "test-v16",
        "activate_snapshot": false,
        "files": [
          {
            "path": "src/components/Hello.tsx",
            "content": "import React from 'react';\nexport function Hello() {\n  return <div>Hi</div>;\n}\nexport const useGreeter = () => 'hi';\n"
          }
        ]
      },
      "expectedStatus": 200,
      "expectedBody": {"success": true, "activated": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Activate snapshot missing id",
      "method": "POST",
      "path": "/",
      "body": {"action": "index.activate_snapshot"},
      "expectedStatus": 400,
      "expectedBody": {"error": "snapshot_id_required"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action",
      "method": "POST",
      "path": "/",
      "body": {"action": "foo.bar"},
      "expectedStatus": 400,
      "expectedBody": {"error": "unknown_action"},
      "bodyMatcher": "partial"
    }
  ]
}