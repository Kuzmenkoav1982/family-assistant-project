{
  "tests": [
    {
      "name": "Register with email - validation error",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "register",
        "email": "test@example.com",
        "password": "123"
      },
      "expectedStatus": 400,
      "expectedBody": {
        "error": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with email - missing credentials",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "login",
        "email": "",
        "password": ""
      },
      "expectedStatus": 400,
      "expectedBody": {
        "error": "string"
      },
      "bodyMatcher": "partial"
    },
    {
      "name": "Handle OPTIONS for CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Register with email + invalid invite_code",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "register",
        "email": "invitetest_smoke@example.com",
        "password": "password123",
        "name": "Тест",
        "invite_code": "INVALID1"
      },
      "expectedStatus": 400,
      "expectedBody": {
        "error": "string"
      },
      "bodyMatcher": "partial"
    }
  ]
}