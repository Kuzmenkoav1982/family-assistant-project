{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Missing user id returns 401",
      "method": "GET",
      "path": "/?resource=entries",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown resource returns 400",
      "method": "GET",
      "path": "/?resource=unknown",
      "headers": {"X-User-Id": "00000000-0000-0000-0000-000000000000"},
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
