{
  "tests": [
    {
      "name": "OPTIONS request for CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": "",
      "bodyMatcher": "exact"
    },
    {
      "name": "Users (legacy) without token rejected",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "expectedBody": {"error": "Требуются права администратора"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Users (legacy) with token",
      "method": "GET",
      "path": "/",
      "headers": {"X-Admin-Token": "admin_authenticated"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Families list",
      "method": "GET",
      "path": "/?resource=families",
      "headers": {"X-Admin-Token": "admin_authenticated"},
      "expectedStatus": 200,
      "expectedBody": {"summary": {}},
      "bodyMatcher": "partial"
    },
