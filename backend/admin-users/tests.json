{
  "tests": [
    {
      "name": "OPTIONS request for CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": "",
      "bodyMatcher": "exact"
    },
    {
      "name": "No token → 401",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "expectedBody": {"error": "Требуются права администратора"},
      "bodyMatcher": "partial"
    },
    {
      "name": "X-Admin-Token legacy header → 401",
      "method": "GET",
      "path": "/",
      "headers": {"X-Admin-Token": "admin_authenticated"},
      "expectedStatus": 401
    },
    {
      "name": "Public flags (no auth required)",
      "method": "GET",
      "path": "/?resource=public_flags",
      "expectedStatus": 200,
      "expectedBody": {},
      "bodyMatcher": "partial"
    },
    {
      "name": "Client error submission (no auth required)",
      "method": "POST",
      "path": "/?resource=errors",
      "body": {"message": "test error", "path": "/test"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    }
  ]
}
